# AWS
AWS_REGION=eu-west-1
S3_BUCKET=your-compression-bucket
SAGEMAKER_ROLE_ARN=arn:aws:iam::123456789012:role/SageMakerExecutionRole
SAGEMAKER_IMAGE_URI=123456789012.dkr.ecr.eu-west-1.amazonaws.com/nemo-compression:latest
SAGEMAKER_INSTANCE_TYPE=ml.p3.2xlarge

# HuggingFace (only needed for gated models like Llama)
HF_TOKEN=

# App
APP_PASSWORD=changeme
